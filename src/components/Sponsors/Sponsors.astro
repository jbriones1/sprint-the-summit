---
/**
 * * Sponsors marquee
 */

import { getGoldSponsors } from '@config/sponsorData.json';
import { Marquee, MarqueeContent } from '@ui/marquee';
import { Image } from 'astro:assets';
---

<section id="portfolio" class="site-container mt-12 scroll-mt-10 py-8 md:py-12">
  <div class="mx-auto max-w-6xl text-center">
    <h3 class="h3 text-pretty uppercase">Sponsored by</h3>
  </div>
  <Marquee class="mt-8">
    <MarqueeContent>
      {
        getGoldSponsors().map(sponsor => (
          <Image src={sponsor.image} alt={sponsor.title} class="w-24 object-contain" />
        ))
      }
      {
        getGoldSponsors().map(sponsor => (
          <Image src={sponsor.image} alt={sponsor.title} class="w-24 object-contain" />
        ))
      }
    </MarqueeContent>
  </Marquee>
</section>
