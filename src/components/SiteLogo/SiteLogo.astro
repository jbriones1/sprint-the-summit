---
import siteData from '@config/siteData.json';
import logo from '@images/logo.svg';
import { Image } from 'astro:assets';

const { showLogo = false } = Astro.props;
---

<a class="primary-focus flex items-center align-middle" href="/" aria-label="Home" class="">
  {
    showLogo && (
      <Image
        src={logo}
        alt="Sprint the Summit logo"
        loading="eager"
        width={100}
        height={100}
        class="mr-2 h-12 w-12 md:h-18 md:w-18"
      />
    )
  }
  <div
    class:list={[
      'font-heading-1',
      'text-3xl',
      'uppercase',
      { hidden: showLogo == true },
      { 'md:block': showLogo == true }
    ]}
  >
    {siteData.name}
  </div>
</a>
