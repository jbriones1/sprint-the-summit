---
/**
 * * Organized by section
 */

import sfssLogo from '@assets/images/sfss-logo.png';
import { Image } from 'astro:assets';
---

<section id="about" class="site-container scroll-mt-10 py-8 md:py-12">
  <h2 class="h3 text-primary-500 text-pretty uppercase">Organized by the SFSS</h2>
  <div class="flex flex-col md:flex-row">
    <div class="md:w-2/3">
      <div class="bg-base-100 mt-8 p-8 md:mb-20 lg:text-lg">
        <p>
          Sprint the Summit is hosted by the Simon Fraser Student Society (SFSS), representing
          25,000+ students across 360+ SFU programs. The SFSS runs major campus events and community
          initiatives focused on student life, wellness, and connection — and Sprint the Summit is
          our newest effort to inspire healthy, active living and build a lasting Burnaby Mountain
          tradition.
        </p>
      </div>
    </div>
    <div class="mr-auto flex max-w-md justify-center p-4 md:w-1/3 md:max-w-none">
      <Image src={sfssLogo} alt="SFSS Logo" densities={[1.5, 2]} class="object-contain" />
    </div>
  </div>
</section>
