---
import sfuAerial3 from '@assets/images/sfu-aerial-3.jpg';
import tfox4 from '@assets/images/tfox-run-4.jpg';
import tfox5 from '@assets/images/tfox-run-5.jpg';
import tfox6 from '@assets/images/tfox-run-6.jpg';
import Button from '@components/Button/Button.astro';
import Tricon from '@components/FeatureCard/Tricon.astro';
import VenueMap from '@components/FeatureCard/VenueMap.astro';
import ImageSection from '@components/ImageSection/ImageSection.astro';
import { eventDate } from '@config/eventData.json';
import PageLayout from '@layouts/PageLayout.astro';
import { Image } from 'astro:assets';

const icons = [
  {
    href: '#schedule',
    descriptor: 'Schedule',
    iconName: 'common/calendar'
  },
  {
    href: '#tips',
    descriptor: 'Tips',
    iconName: 'common/lightbulb'
  }
];
---

<PageLayout title={'Register'} description={'Register for Sprint the Summit.'}>
  <div class="flex flex-col gap-10">
    <Tricon icons={icons} />
    <ImageSection
      id="register"
      backgroundImage={sfuAerial3}
      backgroundImageAlt="Aerial shot of SFU"
    >
      <div class="bg-base-100 p-8">
        <h2 class="h2 mb-4">Register</h2>
        <div class="grid grid-rows-2 gap-8 md:grid-cols-2 md:grid-rows-1 md:gap-0">
          <div class="border-primary-700 flex h-full flex-col justify-between md:border-r md:pr-4">
            <p>
              Register for Sprint the Summit — SFU Burnaby’s inaugural 12 km run in {
                eventDate(true)
              }. Tickets are $10, and 100% of ticket revenue will be reinvested into charitable
              foundations (such as Make-A-Wish) to support the next generation of students.
            </p>
            <Button variant="primary" class="mx-auto mt-6 px-10" href="/info"> View Routes </Button>
          </div>
          <section id="schedule" class="flex flex-col justify-between md:pl-4">
            <div>
              <h4 class="h4">Schedule</h4>
              <ul class="mt-4 ml-4 list-outside list-disc">
                <li>
                  <strong>Race Day:</strong>
                  {eventDate(true)}
                </li>
              </ul>
            </div>
            <Button
              variant="primary"
              class="mx-auto mt-6 px-10"
              href="https://www.bouncelife.com/events/69a633e483f768114efc4102"
              target="_blank"
            >
              Register Now
            </Button>
          </section>
        </div>
      </div>
    </ImageSection>

    <VenueMap />
    <Image src={tfox4} alt="Finish line" densities={[1.5, 2, 3]} class="min-h-full w-full" />
    <section id="tips">
      <h3 class="h3">Tips</h3>
      <ul class="mt-4 ml-4 list-outside list-disc">
        <li>Arrive early to find parking, check in smoothly, and warm up before the start.</li>
        <li>
          Dress for variable Burnaby Mountain weather (layers recommended) and bring a refillable
          water bottle.
        </li>
        <li>
          Follow volunteer/traffic-controller direction and use water stations along the route.
        </li>
      </ul>
    </section>

    <div class="grid grid-rows-2 gap-2 md:grid-cols-2 md:grid-rows-1">
      <Image src={tfox5} alt="Terry Fox 5" densities={[1.5, 2, 3]} class="min-h-full w-full" />
      <Image src={tfox6} alt="Terry Fox 6" densities={[1.5, 2, 3]} class="min-h-full w-full" />
    </div>
  </div>
</PageLayout>
