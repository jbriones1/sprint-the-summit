---
/**
 * * Volunteer section
 */
import FeatureCard from '@components/FeatureCard/FeatureCard.astro';
import volunteerImage from '@images/volunteer1.jpg';
---

<section id="volunteer" class="site-container">
  <FeatureCard
    title="Volunteer"
    image={volunteerImage}
    imageAlt="Volunteers"
    href="/volunteer"
    buttonText="Join our team"
  >
    Volunteers are a key part of making Sprint the Summit safe, welcoming, and fun. Help with
    set-up, check-in, water stations, route marshalling, and tear-down — and gain hands-on event
    experience while supporting an inclusive wellness event on campus. Volunteers can receive event
    operations training and CCR hours.
  </FeatureCard>
</section>
