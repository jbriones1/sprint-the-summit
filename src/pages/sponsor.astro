---
import Button from '@components/Button/Button.astro';
import SplitCard from '@components/FeatureCard/SplitCard.astro';
import SponsorCards from '@components/SponsorCards/SponsorCards.astro';
import PageLayout from '@layouts/PageLayout.astro';
---

<PageLayout title={'Sponsor'} description={'Partner up to make this event a success!'}>
  <h2 class="h2 my-8 text-center">A huge thank you to our sponsors!</h2>
  <SponsorCards />
  <SplitCard title="Become a Sponsor">
    <div slot="first" class="flex h-full flex-col justify-between">
      <p>
        Sprint the Summit is Burnaby Mountain’s first and only community running event of its kind,
        with 500+ expected participants and strong reach across SFU’s 25,000+ student community.
        Sponsorships create meaningful visibility on race day and online — and help us deliver an
        inclusive event that promotes student wellness and community connection. Interested in
        sponsoring? We can customize packages to match your goals.
      </p>
      <div class="flex justify-center">
        <Button variant="primary" class="mt-12 w-fit" href="/contact"> Contact Us </Button>
      </div>
    </div>
    <div slot="second" class="flex h-full flex-col justify-between">
      <h4 class="h4">Sponsorship Tiers</h4>
      <ul class="mt-4 ml-4 list-outside list-disc">
        <li>Title ($5000)</li>
        <li>Gold ($2000)</li>
        <li>Silver ($1000)</li>
        <li>Bronze ($500)</li>
        <li>In-Kind</li>
      </ul>
      <p class="pt-4">
        Benefits include combinations of being thanked on stage, stage time, remarks at closing,
        on-stage product promotion, title branding, logo on website/merch, social promotion, route
        banners, placard logo, free entries, sponsor booth, social media takeover, and more!.
      </p>
      <div class="flex justify-center">
        <Button variant="primary" class="mt-12 w-fit" href="/sts-sponsorship.pdf">Learn More</Button
        >
      </div>
    </div>
  </SplitCard>
</PageLayout>
